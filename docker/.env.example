# Copy to docker/.env or project root .env for compose (do not commit secrets).

# MongoDB Atlas or local instance reachable from containers
MTES_MONGODB_URI=mongodb://host.docker.internal:27017/mtes

# Optional override for mounted config in production
MTES_CONFIG_PATH=/app/config/config.example.yaml

MTES_HEALTH_PORT=8080
MTES_METRICS_PORT=9090
